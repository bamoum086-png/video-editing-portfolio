<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Marisa Peer | Visual Performance Audit</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Inter', 'sans-serif'] },
                    colors: {
                        dark: '#0f172a',
                        darker: '#020617',
                        primary: '#8b5cf6', // Purple for psychology/therapy
                        accent: '#f59e0b',  // Gold for premium/transformation
                        surface: '#1e293b'
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #020617; color: #f8fafc; }
        .glass-panel {
            background: rgba(30, 41, 59, 0.7);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(139, 92, 246, 0.2);
            border-radius: 1rem;
        }
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #020617; }
        ::-webkit-scrollbar-thumb { background: #8b5cf6; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #7c3aed; }
        
        .tab-btn.active {
            border-bottom: 2px solid #f59e0b;
            color: #f59e0b;
            background: rgba(245, 158, 11, 0.1);
        }
    </style>
</head>
<body class="min-h-screen p-4 md:p-8 selection:bg-primary selection:text-white pb-24">

    <!-- Header -->
    <header class="max-w-7xl mx-auto mb-8 flex flex-col md:flex-row justify-between items-center gap-4">
        <div>
            <h1 class="text-3xl md:text-4xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-primary to-accent mb-2">
                Visual Performance Audit | Marisa Peer
            </h1>
            <p class="text-gray-400">Direct-Response Analysis & AI-Driven Optimization Strategy</p>
            <div class="mt-4">
                <a href="https://www.instagram.com/marisapeertherapy/reels/?hl=en" target="_blank" class="inline-flex items-center gap-2 bg-gradient-to-r from-pink-600 to-purple-600 hover:from-pink-500 hover:to-purple-500 text-white shadow-lg shadow-pink-500/20 px-4 py-2 rounded-full text-sm font-bold transition-transform hover:scale-105">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                    Instagram Account
                </a>
            </div>
        </div>
        <div class="glass-panel px-6 py-3 border-r-4 border-r-accent flex items-center gap-4">
            <div class="text-right mr-4">
                <p class="text-sm text-gray-400">Prepared for:</p>
                <p class="font-bold text-white">NOLIMIT ECOMMERCE</p>
            </div>
            <img src="https://ui-avatars.com/api/?name=N+E&background=f59e0b&color=fff&rounded=true" alt="Client" class="w-12 h-12 rounded-full border-2 border-accent">
        </div>
    </header>

    <!-- Navigation Tabs -->
    <div class="max-w-7xl mx-auto mb-6 flex overflow-x-auto border-b border-gray-700">
        <button onclick="switchTab('audit')" id="tab-audit" class="tab-btn active px-6 py-3 font-bold transition whitespace-nowrap">1. Interactive Visual Audit</button>
        <button onclick="switchTab('psychology')" id="tab-psychology" class="tab-btn px-6 py-3 font-bold transition whitespace-nowrap text-gray-400 hover:text-gray-200">2. Psychological Gap Analysis</button>
        <button onclick="switchTab('strategy')" id="tab-strategy" class="tab-btn px-6 py-3 font-bold transition whitespace-nowrap text-gray-400 hover:text-gray-200">3. Proposed Ad Strategy</button>
    </div>

    <!-- Main Content Area -->
    <main class="max-w-7xl mx-auto relative">

        <!-- TAB 1: Interactive Audit -->
        <div id="content-audit" class="grid grid-cols-1 lg:grid-cols-2 gap-6 animate-fade-in">
            <!-- Evaluation Sliders -->
            <div class="glass-panel p-6">
                <div class="flex flex-col xl:flex-row xl:items-center justify-between mb-6 gap-3 border-b border-gray-700/50 pb-4">
                    <h2 class="text-xl font-bold text-white flex items-center gap-2">
                        <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
                        Assets Evaluation
                    </h2>
                    <div class="flex items-center gap-2 bg-slate-800/80 border border-gray-600 rounded-lg p-1.5 shadow-inner">
                        <span class="text-xs font-semibold text-gray-400 pl-2 uppercase tracking-wider">Format:</span>
                        <select id="assetFormat" class="bg-transparent text-sm font-bold text-accent focus:outline-none cursor-pointer pr-4 hover:text-yellow-300 transition-colors">
                            <option value="statics" class="bg-slate-800 text-white">Static Ads (Meta)</option>
                            <option value="reels" class="bg-slate-800 text-white">Video / Reels (IG/TikTok)</option>
                            <option value="google" class="bg-slate-800 text-white">Google Posts</option>
                            <option value="carousel" class="bg-slate-800 text-white">Carousel Ads</option>
                        </select>
                    </div>
                </div>
                
                <div class="space-y-6">
                    <div>
                        <div class="flex justify-between mb-1">
                            <label class="text-sm font-bold text-gray-300">Pattern Interrupt Power (First 3 Seconds)</label>
                            <span id="val-hook" class="text-accent font-bold">5/10</span>
                        </div>
                        <input type="range" id="slider-hook" min="1" max="10" value="5" class="w-full h-2 bg-gray-700 rounded-lg appearance-none cursor-pointer accent-primary" oninput="updateChart()">
                        <p class="text-xs text-gray-500 mt-1">Content leans towards traditional "Talking Head". Needs a visual shock to increase scroll-stop rates.</p>
                    </div>

                    <div>
                        <div class="flex justify-between mb-1">
                            <label class="text-sm font-bold text-gray-300">Visualizing Pain Points</label>
                            <span id="val-pain" class="text-accent font-bold">3/10</span>
                        </div>
                        <input type="range" id="slider-pain" min="1" max="10" value="3" class="w-full h-2 bg-gray-700 rounded-lg appearance-none cursor-pointer accent-primary" oninput="updateChart()">
                        <p class="text-xs text-gray-500 mt-1">Heavy reliance on text. Lacks visual representation of emotional 'rejection' or 'mental blocks'.</p>
                    </div>

                    <div>
                        <div class="flex justify-between mb-1">
                            <label class="text-sm font-bold text-gray-300">Native UI Experience</label>
                            <span id="val-native" class="text-accent font-bold">6/10</span>
                        </div>
                        <input type="range" id="slider-native" min="1" max="10" value="6" class="w-full h-2 bg-gray-700 rounded-lg appearance-none cursor-pointer accent-primary" oninput="updateChart()">
                        <p class="text-xs text-gray-500 mt-1">Designs look like explicit "ads" rather than native organic content blending with the user feed.</p>
                    </div>
                    
                    <div>
                        <div class="flex justify-between mb-1">
                            <label class="text-sm font-bold text-gray-300">Color Contrast & Visual Hierarchy</label>
                            <span id="val-color" class="text-accent font-bold">7/10</span>
                        </div>
                        <input type="range" id="slider-color" min="1" max="10" value="7" class="w-full h-2 bg-gray-700 rounded-lg appearance-none cursor-pointer accent-primary" oninput="updateChart()">
                    </div>
                </div>
            </div>

            <!-- Radar Chart -->
            <div class="glass-panel p-6 flex flex-col items-center justify-center">
                <h3 class="text-lg font-bold text-gray-300 mb-4">Performance Gap Chart</h3>
                <div class="w-full max-w-[300px] aspect-square relative">
                    <canvas id="auditChart"></canvas>
                </div>
                <div id="result-box" class="mt-6 p-4 bg-purple-900/20 border border-purple-500/50 rounded-lg w-full text-center transition-all duration-500">
                    <p class="text-sm text-gray-300 font-bold mb-1">Strategic Diagnosis:</p>
                    <p id="dynamic-title" class="text-lg font-bold text-white mt-1 transition-all duration-300">Intervention Zone: <span class="text-purple-400 text-3xl font-black">45%</span> gap in visualizing pain.</p>
                    <p id="dynamic-desc" class="text-sm text-gray-400 mt-2 transition-all duration-300">Requires a strategic AI intervention to translate this suffering into interactive imagery, increasing CTR and lowering CPA.</p>
                </div>
            </div>
        </div>

        <!-- TAB 2: Audience Psychology -->
        <div id="content-psychology" class="hidden grid-cols-1 md:grid-cols-3 gap-6 animate-fade-in">
            <div class="glass-panel p-6 border-t-4 border-t-red-500">
                <h3 class="text-xl font-bold text-white mb-4">Core Pain Points</h3>
                <ul class="space-y-3 text-gray-300 text-sm">
                    <li class="flex items-start gap-2"><span class="text-red-500">✖</span> Inner deficiency beliefs: "I Am Not Enough".</li>
                    <li class="flex items-start gap-2"><span class="text-red-500">✖</span> Deep-rooted financial barriers (Money Blocks).</li>
                    <li class="flex items-start gap-2"><span class="text-red-500">✖</span> Unresolved childhood traumas affecting relationships.</li>
                    <li class="flex items-start gap-2"><span class="text-red-500">✖</span> Emotional eating and psychological attachment to weight.</li>
                </ul>
            </div>
            
            <div class="glass-panel p-6 border-t-4 border-t-accent">
                <h3 class="text-xl font-bold text-white mb-4">Transformational Desires</h3>
                <ul class="space-y-3 text-gray-300 text-sm">
                    <li class="flex items-start gap-2"><span class="text-accent">★</span> Achieving rapid, radical results (RTT methodology).</li>
                    <li class="flex items-start gap-2"><span class="text-accent">★</span> Regaining absolute confidence in decisions and appearance.</li>
                    <li class="flex items-start gap-2"><span class="text-accent">★</span> Stopping the cycle of unconscious self-sabotage.</li>
                </ul>
            </div>

            <div class="glass-panel p-6 border-t-4 border-t-primary">
                <h3 class="text-xl font-bold text-white mb-4">Proposed Visual Solution</h3>
                <p class="text-gray-300 text-sm leading-relaxed mb-4">
                    Traditional stock photos fail to capture concepts like the "Inner Child" or "Mental Boundaries". We propose using advanced AI generation combined with professional compositing to create surreal imagery that speaks directly to the prospect's subconscious mind.
                </p>
                <div class="bg-darker p-3 rounded border border-gray-700">
                    <p class="text-xs text-primary font-bold">Core Advertising Goal:</p>
                    <p class="text-sm text-white italic">"Make the familiar unfamiliar, and the unfamiliar familiar." - A visual reflection of Marisa Peer's philosophy.</p>
                </div>
            </div>
        </div>

        <!-- TAB 3: Proposed Strategy -->
        <div id="content-strategy" class="hidden space-y-6 animate-fade-in">
            <div class="glass-panel p-6">
                <h2 class="text-2xl font-bold text-accent mb-4">Actionable Execution Concepts</h2>
                <p class="text-gray-300 mb-6">Practical examples of translating psychological analysis into high-converting ad assets:</p>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Concept 1 -->
                    <div class="bg-slate-800/50 p-5 rounded-xl border border-gray-700 hover:border-primary transition">
                        <div class="flex justify-between items-center mb-3">
                            <h3 class="text-lg font-bold text-white">Concept 1: "The Inner Child Reflection"</h3>
                            <span class="text-xs bg-primary/20 text-primary px-2 py-1 rounded">Pattern Interrupt</span>
                        </div>
                        <p class="text-sm text-gray-400 mb-3"><strong class="text-gray-200">Visual Concept (AI Gen):</strong> A UGC/iPhone style image of an adult looking frustrated in the mirror, but the reflection shows a scared child version of themselves. Cinematic yet highly realistic lighting.</p>
                        <p class="text-sm text-gray-400"><strong class="text-gray-200">Technical Compositing:</strong> Flawlessly fixing AI artifacts, adding a native Reels/TikTok UI overlay, and integrating a hook text that directly ties the image to the prospect's relationship struggles.</p>
                    </div>

                    <!-- Concept 2 -->
                    <div class="bg-slate-800/50 p-5 rounded-xl border border-gray-700 hover:border-accent transition">
                        <div class="flex justify-between items-center mb-3">
                            <h3 class="text-lg font-bold text-white">Concept 2: "The Invisible Boundaries"</h3>
                            <span class="text-xs bg-accent/20 text-accent px-2 py-1 rounded">Visual Metaphor</span>
                        </div>
                        <p class="text-sm text-gray-400 mb-3"><strong class="text-gray-200">Visual Concept (AI Gen):</strong> A persona representing the target audience reaching forward for an opportunity or money, but their hands hit an invisible, slightly cracked glass wall (visualizing Money Blocks / Self-sabotage).</p>
                        <p class="text-sm text-gray-400"><strong class="text-gray-200">Technical Compositing:</strong> Precise color contrast adjustments to catch the eye during scrolling, and integrating text elements simulating Price Anchoring to highlight the 21-day solution.</p>
                    </div>
                </div>
            </div>
            
            <!-- Professional Summary Box -->
            <div class="glass-panel p-6 border-l-4 border-l-blue-500 bg-blue-900/10 flex items-center justify-between">
                <div>
                    <h3 class="text-lg font-bold text-blue-400 mb-2">Proposed Next Steps</h3>
                    <p class="text-sm text-gray-200 leading-relaxed max-w-3xl">
                        To prove the effectiveness of this visual methodology, I propose executing an A/B Split Test by designing 3 ad assets based on this psycho-visual analysis, and comparing their CTRs against your team's current top-performing ads.
                    </p>
                </div>
            </div>
        </div>

    </main>

    <script>
        // Tab Switching Logic
        function switchTab(tabId) {
            document.getElementById('content-audit').classList.add('hidden');
            document.getElementById('content-psychology').classList.add('hidden');
            document.getElementById('content-strategy').classList.add('hidden');
            
            document.getElementById('tab-audit').classList.remove('active', 'text-gray-200');
            document.getElementById('tab-audit').classList.add('text-gray-400');
            document.getElementById('tab-psychology').classList.remove('active', 'text-gray-200');
            document.getElementById('tab-psychology').classList.add('text-gray-400');
            document.getElementById('tab-strategy').classList.remove('active', 'text-gray-200');
            document.getElementById('tab-strategy').classList.add('text-gray-400');

            document.getElementById('content-' + tabId).classList.remove('hidden');
            const activeBtn = document.getElementById('tab-' + tabId);
            activeBtn.classList.add('active');
            activeBtn.classList.remove('text-gray-400');
        }

        // Radar Chart Initialization
        let auditChart;
        const ctx = document.getElementById('auditChart').getContext('2d');

        function initChart() {
            const data = {
                labels: ['Pattern Interrupt (Hook)', 'Visualizing Pain', 'Native UI Experience', 'Color Contrast'],
                datasets: [{
                    label: 'Current Campaign Status',
                    data: [5, 3, 6, 7],
                    backgroundColor: 'rgba(139, 92, 246, 0.2)',
                    borderColor: 'rgba(139, 92, 246, 1)',
                    pointBackgroundColor: 'rgba(245, 158, 11, 1)',
                    pointBorderColor: '#fff',
                    pointHoverBackgroundColor: '#fff',
                    pointHoverBorderColor: 'rgba(245, 158, 11, 1)',
                    borderWidth: 2,
                },
                {
                    label: 'Target Conversion Benchmark',
                    data: [10, 10, 9, 9],
                    backgroundColor: 'rgba(245, 158, 11, 0.1)',
                    borderColor: 'rgba(245, 158, 11, 0.5)',
                    borderDash: [5, 5],
                    borderWidth: 1,
                    pointRadius: 0
                }]
            };

            const config = {
                type: 'radar',
                data: data,
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        r: {
                            angleLines: { color: 'rgba(255, 255, 255, 0.1)' },
                            grid: { color: 'rgba(255, 255, 255, 0.1)' },
                            pointLabels: { color: '#94a3b8', font: { family: 'Inter', size: 12 } },
                            ticks: { display: false, min: 0, max: 10 }
                        }
                    },
                    plugins: {
                        legend: { display: false }
                    }
                }
            };

            auditChart = new Chart(ctx, config);
        }

        // Update Chart based on Sliders
        function updateChart() {
            const hook = parseInt(document.getElementById('slider-hook').value);
            const pain = parseInt(document.getElementById('slider-pain').value);
            const native = parseInt(document.getElementById('slider-native').value);
            const color = parseInt(document.getElementById('slider-color').value);

            document.getElementById('val-hook').innerText = hook + '/10';
            document.getElementById('val-pain').innerText = pain + '/10';
            document.getElementById('val-native').innerText = native + '/10';
            document.getElementById('val-color').innerText = color + '/10';

            auditChart.data.datasets[0].data = [hook, pain, native, color];
            auditChart.update();

            const totalScore = hook + pain + native + color;
            const maxScore = 40;
            const currentPercentage = (totalScore / maxScore) * 100;
            const gap = Math.round(100 - currentPercentage);
            
            let titleHtml = "";
            let descText = "";
            let boxColor = ""; 

            if (gap >= 85) {
                titleHtml = `Critical Drop: <span class="text-red-500 text-3xl font-black">${gap}%</span> gap in Direct-Response alignment.`;
                descText = "Current visuals fail to stop the target audience. Immediate and comprehensive visual restructuring is recommended.";
                boxColor = "bg-red-900/20 border-red-500/50";
            } else if (gap >= 75) {
                titleHtml = `Conversion Leakage: <span class="text-red-400 text-3xl font-black">${gap}%</span> gap in psychological visualization.`;
                descText = "Great copy, but the visual packaging fails to deliver the message. AI-generated imagery can plug this leak effectively.";
                boxColor = "bg-red-800/20 border-red-400/50";
            } else if (gap >= 65) {
                titleHtml = `Major Optimization Opportunity: <span class="text-orange-500 text-3xl font-black">${gap}%</span> gap in attention capture.`;
                descText = "Urgent need for a Pattern Interrupt strategy using surreal images that stop the user from scrolling.";
                boxColor = "bg-orange-900/20 border-orange-500/50";
            } else if (gap >= 55) {
                titleHtml = `Average Performance: <span class="text-amber-500 text-3xl font-black">${gap}%</span> gap in engagement.`;
                descText = "Visual assets lack Native UI authenticity. Applying advanced compositing will give the ad an organic feel, increasing trust.";
                boxColor = "bg-amber-900/20 border-amber-500/50";
            } else if (gap >= 45) {
                titleHtml = `Intervention Zone: <span class="text-purple-400 text-3xl font-black">${gap}%</span> gap in visualizing pain.`;
                descText = "Requires a strategic AI intervention to translate this suffering into interactive imagery, increasing CTR and lowering CPA.";
                boxColor = "bg-purple-900/20 border-purple-500/50";
            } else if (gap >= 35) {
                titleHtml = `Good Performance with Room to Grow: <span class="text-yellow-400 text-3xl font-black">${gap}%</span> gap.`;
                descText = "Efficiency can be raised through higher color contrast and playing on deeper emotions with bolder designs.";
                boxColor = "bg-yellow-900/20 border-yellow-500/50";
            } else if (gap >= 25) {
                titleHtml = `Growth Margins: <span class="text-emerald-400 text-3xl font-black">${gap}%</span> gap to reach peak performance.`;
                descText = "Professional lighting adjustments and adding visual hooks will maximize Return on Ad Spend (ROAS).";
                boxColor = "bg-emerald-900/20 border-emerald-500/50";
            } else if (gap >= 15) {
                titleHtml = `Nearing Optimal Benchmark: Only <span class="text-green-400 text-3xl font-black">${gap}%</span> gap.`;
                descText = "Solid performance. Strategy now focuses on micro-optimizations and testing secondary visual angles.";
                boxColor = "bg-green-900/20 border-green-500/50";
            } else if (gap > 0) {
                titleHtml = `Highly Efficient: Negligible <span class="text-teal-400 text-3xl font-black">${gap}%</span> gap.`;
                descText = "Minor surgical corrections are enough to push the campaign to its maximum capacity at the lowest cost.";
                boxColor = "bg-teal-900/20 border-teal-500/50";
            } else {
                titleHtml = `Perfect Visual Performance (<span class="text-blue-400 text-3xl font-black">0%</span> gap).`;
                descText = "Current assets possess all high Direct-Response elements. The goal is to maintain this standard in future asset production.";
                boxColor = "bg-blue-900/20 border-blue-500/50";
            }

            const resultBox = document.getElementById('result-box');
            resultBox.className = `mt-6 p-4 rounded-lg w-full text-center transition-all duration-500 border ${boxColor}`;
            document.getElementById('dynamic-title').innerHTML = titleHtml;
            document.getElementById('dynamic-desc').innerText = descText;
        }

        window.onload = () => {
            initChart();
            const style = document.createElement('style');
            style.innerHTML = `
                .animate-fade-in {
                    animation: fadeIn 0.4s ease-in-out;
                }
                @keyframes fadeIn {
                    from { opacity: 0; transform: translateY(10px); }
                    to { opacity: 1; transform: translateY(0); }
                }
            `;
            document.head.appendChild(style);
        };
    </script>
</body>
</html>
